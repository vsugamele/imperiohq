# Facebook Conversions API — Fase 3C
# Preencha com seus dados do Gerenciador de Eventos do Facebook
# Docs: https://developers.facebook.com/docs/marketing-api/conversions-api

# ID do Pixel (ex: 123456789012345)
FB_PIXEL_ID=

# Access Token gerado em: Gerenciador de Eventos → Configurações → Token de Acesso da API
FB_ACCESS_TOKEN=

# Código de evento de teste (opcional — use apenas em dev/homolog)
# Obtenha em: Gerenciador de Eventos → Testar Eventos → "Código de teste"
FB_TEST_EVENT_CODE=
